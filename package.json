{
  "name": "@atao60/email-campaign-manager-root",
  "description": "A full-stack Email Campaign Manager using Lit, tsoa, and Clean Architecture.",
  "private": true,
  "workspaces": [
    "backend",
    "client"
  ],
  "scripts": {
    "prepare": "husky",
    "install:all": "npm install",
    "start:dev:backend": "npm run start:dev -w @campaign-manager/backend",
    "start:dev:web": "wait-on tcp:3000 && npm run start:dev -w @campaign-manager/client",
    "start:web": "concurrently \"npm run start:dev:backend\" \"npm run start:dev:web\"",
    "test:backend": "npm test -w @campaign-manager/backend",
    "test:web": "npm test -w @campaign-manager/client",
    "test": "npm run test:backend && npm run test:web",
    "coverage:backend": "npm run coverage -w @campaign-manager/backend",
    "coverage:web": "npm run coverage -w @campaign-manager/client",
    "coverage": "npm run coverage:backend && npm run coverage:web",
    "format": "prettier --write .",
    "release": "release-it"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@release-it/conventional-changelog": "^11.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "json": "^11.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "release-it": "^20.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "wait-on": "^9.0.5"
  },
  "author": "Pierre Raoul <atao60.dev@gmail.com>",
  "license": "MIT",
  "keywords": [
    "mailing",
    "email",
    "campaign",
    "typescript",
    "DDD",
    "hexagonal",
    "SOLID",
    "API",
    "CLI",
    "REST",
    "WEB",
    "SPA"
  ]
}
