{
  "name": "@campaign-manager/client",
  "private": true,
  "version": "0.0.5",
  "description": "The Lit-based SPA frontend for the Email Campaign Manager",
  "type": "module",
  "scripts": {
    "start": "npm run wait:dev:app",
    "start:dev:app": "vite",
    "wait:dev:app": "wait-on tcp:3000 && npm run start:dev:app",
    "start:dev": "npm run wait:dev:app",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "npm run test -- --coverage",
    "i18n:extract": "i18next-cli extract --config i18next-cli.config.ts",
    "tree": "npx tree-console -d ./src",
    "analyse:bundle": "vite-bundle-visualizer"
  },
  "dependencies": {
    "@campaign-manager/backend": "*",
    "i18next": "^26.1.0",
    "i18next-http-backend": "^4.0.0",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "i18next-cli": "^1.56.12",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass": "^1.99.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-bundle-visualizer": "^1.2.1",
    "vite-plugin-lit-css": "^2.2.2",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.10"
  }
}
